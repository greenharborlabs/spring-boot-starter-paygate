# Integration test environment — configurable ports
# Override any of these to avoid conflicts with services on your host.

# bitcoind RPC port (regtest)
BITCOIND_RPC_PORT=18443

# LND gRPC port
LND_GRPC_PORT=10009

# LND REST port
LND_REST_PORT=8081

# LNbits HTTP port
LNBITS_PORT=5000

# Example app HTTP port
APP_PORT=8080
